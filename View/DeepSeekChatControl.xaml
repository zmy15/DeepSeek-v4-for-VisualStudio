<UserControl x:Class="DeepSeek_v4_for_VisualStudio.View.DeepSeekChatControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="600">
    <UserControl.Resources>
        <!-- ═══ 深色主题样式 ═══ -->
        <!-- ComboBox 深色样式（完整自定义模板，保持所有下拉元素深色） -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          ClickMode="Press"
                                          SnapsToDevicePixels="True">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ToggleBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="3"
                                                SnapsToDevicePixels="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="6,3,0,3"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Center"
                                                                  RecognizesAccessKey="True"/>
                                                <Path Grid.Column="1"
                                                      Data="M0,0 L4,4 L8,0"
                                                      Fill="#888888"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Stroke="#888888"
                                                      StrokeThickness="1"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ToggleBorder" Property="Background" Value="#4A4A4A"/>
                                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#666666"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="8,3,25,3"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide"
                                   SnapsToDevicePixels="True">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="#3C3C3C"
                                            BorderBrush="#555555"
                                            BorderThickness="1"
                                            CornerRadius="3"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem 深色样式 -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="2">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#505050"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#264F78"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox 深色样式 -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- 透明按钮样式 -->
        <Style x:Key="TransparentButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3C3C3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#505050"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#666666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ 会话选择栏 ═══ -->
        <Border Grid.Row="0"
                Background="#252526"
                BorderBrush="#3C3C3C" BorderThickness="0,0,0,1"
                Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0"
                          x:Name="SessionComboBox"
                          MinWidth="160"
                          SelectionChanged="SessionComboBox_SelectionChanged"
                          DisplayMemberPath="Title" />

                <Button Grid.Column="1"
                        x:Name="DeleteSessionButton"
                        Content="✕"
                        ToolTip="删除当前对话"
                        Click="DeleteSessionButton_Click"
                        Style="{StaticResource TransparentButton}"
                        FontSize="12" Padding="8,2" Margin="4,0,0,0"
                        Foreground="#888888" />
            </Grid>
        </Border>

        <!-- ═══ WebView2 聊天显示区 (Chromium) ═══ -->
        <wv2:WebView2 Grid.Row="1"
                      x:Name="ChatWebView"
                      Margin="0" />

        <!-- ═══ Diff 预览全局控制栏 ═══ -->
        <Border Grid.Row="2"
                x:Name="DiffGlobalBar"
                Background="#1B5E20"
                BorderBrush="#2E7D32"
                BorderThickness="0,1,0,1"
                Padding="10,4"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           x:Name="DiffGlobalLabel"
                           Foreground="#E0E0E0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Text="📊 检测到文件变更" />
                <TextBlock Grid.Column="1"
                           x:Name="DiffGlobalDetail"
                           Foreground="#A0D0A0"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0" />
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="UndoAllButton"
                            Content="↩️ 撤销全部"
                            Click="UndoAllDiffButton_Click"
                            Background="#8B2E2E"
                            Foreground="White"
                            BorderBrush="#B84040"
                            BorderThickness="1"
                            MinWidth="90" MinHeight="26"
                            FontSize="11" FontWeight="SemiBold"
                            Cursor="Hand"
                            Padding="10,3"
                            Margin="0,0,8,0" />
                    <Button x:Name="AcceptAllButton"
                            Content="✅ 接受全部"
                            Click="AcceptAllDiffButton_Click"
                            Background="#2E7D32"
                            Foreground="White"
                            BorderBrush="#4CAF50"
                            BorderThickness="1"
                            MinWidth="90" MinHeight="26"
                            FontSize="11" FontWeight="SemiBold"
                            Cursor="Hand"
                            Padding="10,3" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ 状态显示 ═══ -->
        <TextBlock Grid.Row="3"
                   x:Name="StatusLabel"
                   FontSize="11"
                   Foreground="#888888"
                   Margin="12,4,12,0" />

        <!-- ═══ 输入区 ═══ -->
        <Border Grid.Row="4"
                Background="#2D2D2D"
                Margin="8,4,8,12" Padding="4" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ➕ 输入框左上角：添加上下文按钮 + Popup -->
                <Button x:Name="AddContextButton" Content="＋"
                        Click="AddContextButton_Click"
                        Style="{StaticResource TransparentButton}"
                        ToolTip="添加上下文：活动文档 / 项目文件 / 项目全部文件 / 选中代码块 / 调试输出"
                        FontSize="18" Padding="6,2"
                        Foreground="#6CAFD9"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="4,4,0,0"
                        Panel.ZIndex="10" />

                <Popup x:Name="AddContextPopup"
                       PlacementTarget="{Binding ElementName=AddContextButton}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       Focusable="False"
                       PopupAnimation="Fade"
                       HorizontalOffset="0"
                       VerticalOffset="4">
                    <Border Background="#2D2D2D"
                            BorderBrush="#555555"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="2"
                            MinWidth="200">
                        <StackPanel>
                            <MenuItem x:Name="AddActiveDocMenuItem" Header="📄 添加活动文档"
                                      Click="AddActiveDocument_Click"
                                      ToolTip="将当前编辑器中的活动文档内容添加到对话上下文"
                                      Background="#2D2D2D" Foreground="#D4D4D4"
                                      Padding="10,6" FontSize="13" />
                            <MenuItem x:Name="AddProjectFileMenuItem" Header="📁 添加项目文件…"
                                      Click="AddProjectFiles_Click"
                                      ToolTip="从项目中选择文件添加到对话上下文"
                                      Background="#2D2D2D" Foreground="#D4D4D4"
                                      Padding="10,6" FontSize="13" />
                            <MenuItem x:Name="AddAllFilesMenuItem" Header="📦 添加项目全部文件"
                                      Click="AddAllProjectFiles_Click"
                                      ToolTip="一键将当前解决方案中所有项目的源代码文件添加到对话上下文"
                                      Background="#2D2D2D" Foreground="#D4D4D4"
                                      Padding="10,6" FontSize="13" />
                            <Separator Background="#555555" Margin="4,2" />
                            <MenuItem x:Name="AddSelectionMenuItem" Header="✂️ 添加选中代码块"
                                      Click="AddSelectedCode_Click"
                                      ToolTip="将编辑器中当前选中的代码块添加到对话上下文"
                                      Background="#2D2D2D" Foreground="#D4D4D4"
                                      Padding="10,6" FontSize="13" />
                            <MenuItem x:Name="AddDebugMenuItem" Header="🐛 添加调试输出"
                                      Click="AddDebugOutput_Click"
                                      ToolTip="将 Visual Studio 输出窗口中的调试信息添加到对话上下文"
                                      Background="#2D2D2D" Foreground="#D4D4D4"
                                      Padding="10,6" FontSize="13" />
                        </StackPanel>
                    </Border>
                </Popup>

                <TextBox Grid.Row="0"
                         x:Name="InputTextBox"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="50" MaxHeight="140"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#D4D4D4"
                         CaretBrush="#D4D4D4"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"
                         Padding="36,4,4,4"
                         PreviewKeyDown="InputTextBox_PreviewKeyDown"
                         TextChanged="InputTextBox_TextChanged"
                         GotFocus="InputTextBox_GotFocus"
                         LostFocus="InputTextBox_LostFocus" />

                <!-- 输入框占位提示文字（无内容且无焦点时显示） -->
                <TextBlock Grid.Row="0"
                           x:Name="InputPlaceholder"
                           Text="输入问题..."
                           Foreground="#555555"
                           FontSize="12"
                           Padding="40,8,8,4"
                           VerticalAlignment="Top"
                           IsHitTestVisible="False"
                           Panel.ZIndex="0" />

                <!-- ═══ Skill 斜杠命令自动补全弹出框 ═══ -->
                <Popup x:Name="SkillSuggestionPopup"
                       PlacementTarget="{Binding ElementName=InputTextBox}"
                       Placement="Top"
                       StaysOpen="True"
                       AllowsTransparency="True"
                       Focusable="False"
                       PopupAnimation="Fade"
                       HorizontalOffset="4"
                       VerticalOffset="-4">
                    <Border Background="#2D2D2D"
                            BorderBrush="#555555"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="2"
                            MinWidth="260"
                            MaxWidth="400"
                            MaxHeight="240">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Text="💡 可用技能 (↑↓ 选择, Enter 确认, Esc 取消)"
                                       FontSize="11"
                                       Foreground="#888888"
                                       Margin="8,6,8,4" />
                            <ListBox Grid.Row="1"
                                     x:Name="SkillSuggestionListBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#D4D4D4"
                                     FontSize="12"
                                     MaxHeight="200"
                                     PreviewKeyDown="SkillSuggestionListBox_PreviewKeyDown"
                                     SelectionChanged="SkillSuggestionListBox_SelectionChanged"
                                     MouseDoubleClick="SkillSuggestionListBox_MouseDoubleClick">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Name, StringFormat='📌 /{0}'}"
                                                       Foreground="#6CAFD9"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       Margin="0,0,8,0" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Description}"
                                                       Foreground="#C8C8C8"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Source}"
                                                       Foreground="#888888"
                                                       FontSize="10"
                                                       Margin="6,0,0,0" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Padding" Value="8,5" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Border"
                                                            Background="{TemplateBinding Background}"
                                                            Padding="{TemplateBinding Padding}"
                                                            CornerRadius="3">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Border" Property="Background" Value="#3C3C3C" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Border" Property="Background" Value="#264F78" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Grid>
                    </Border>
                </Popup>

                <!-- ═══ @Agent 路由自动补全弹出框 ═══ -->
                <Popup x:Name="AgentSuggestionPopup"
                       PlacementTarget="{Binding ElementName=InputTextBox}"
                       Placement="Top"
                       StaysOpen="True"
                       AllowsTransparency="True"
                       Focusable="False"
                       PopupAnimation="Fade"
                       HorizontalOffset="4"
                       VerticalOffset="-4">
                    <Border Background="#2D2D2D"
                            BorderBrush="#555555"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="2"
                            MinWidth="280"
                            MaxWidth="420"
                            MaxHeight="240">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Text="🤖 可用 Agent (↑↓ 选择, Enter 确认, Esc 取消)"
                                       FontSize="11"
                                       Foreground="#888888"
                                       Margin="8,6,8,4" />
                            <ListBox Grid.Row="1"
                                     x:Name="AgentSuggestionListBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#D4D4D4"
                                     FontSize="12"
                                     MaxHeight="200"
                                     PreviewKeyDown="AgentSuggestionListBox_PreviewKeyDown"
                                     SelectionChanged="AgentSuggestionListBox_SelectionChanged"
                                     MouseDoubleClick="AgentSuggestionListBox_MouseDoubleClick">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Icon}"
                                                       FontSize="14"
                                                       Margin="0,0,6,0" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DisplayPrefix}"
                                                       Foreground="#CEA85C"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       Margin="0,0,8,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Description}"
                                                       Foreground="#C8C8C8"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Padding" Value="8,5" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Border"
                                                            Background="{TemplateBinding Background}"
                                                            Padding="{TemplateBinding Padding}"
                                                            CornerRadius="3">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Border" Property="Background" Value="#3C3C3C" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Border" Property="Background" Value="#264F78" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Grid>
                    </Border>
                </Popup>

                <!-- 已上传文件标签区 -->
                <ItemsControl Grid.Row="1"
                              x:Name="AttachedFilesControl"
                              Margin="4,4,4,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#264F78"
                                    CornerRadius="3"
                                    Padding="6,2" Margin="0,0,4,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding}"
                                               Foreground="#D4D4D4"
                                               FontSize="11"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Content="✕"
                                            Foreground="#888888"
                                            FontSize="10"
                                            Style="{StaticResource TransparentButton}"
                                            Padding="2,0"
                                            Margin="4,0,0,0"
                                            Click="RemoveAttachedFile_Click"
                                            Tag="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid Grid.Row="2" Margin="4,8,4,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 左侧: 模型和思考设置 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button x:Name="UploadButton" Content="📎"
                            Click="UploadButton_Click"
                            Style="{StaticResource TransparentButton}"
                            ToolTip="上传文件 (支持 .txt .doc .xls .py .c 等)"
                            FontSize="18" Padding="8,0"
                            Foreground="#CE9178" />
                        <ComboBox x:Name="ModelComboBox"
                                  MinWidth="140" Margin="0,0,8,0"
                                  SelectionChanged="ModelComboBox_SelectionChanged" />
                        <CheckBox x:Name="ThinkingCheckBox"
                                  Content="深度思考"
                                  VerticalAlignment="Center" Margin="0,0,8,0"
                                  Checked="ThinkingCheckBox_Changed"
                                  Unchecked="ThinkingCheckBox_Changed" />
                        <ComboBox x:Name="EffortComboBox"
                                  MinWidth="70" Margin="0,0,8,0"
                                  SelectionChanged="EffortComboBox_SelectionChanged" />
                        <!-- 原来隐藏的 ComboBox，改为默认可见，通过代码控制 -->
                        <ComboBox x:Name="WebSearchEngineComboBox"
                            MinWidth="110" Margin="0,0,8,0"
                            SelectionChanged="WebSearchEngineComboBox_SelectionChanged"
                            ToolTip="选择搜索引擎。百度搜索需在 工具→选项→DeepSeek Chat 中配置 API Key"
                            Visibility="Collapsed" />
                        <!-- 保留 Collapsed，由代码控制显示/隐藏 -->

                    </StackPanel>

                    <!-- 右侧: 操作按钮 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <!-- 联网搜索切换按钮 -->
                        <Button x:Name="WebSearchToggleButton"
                                Click="WebSearchToggleButton_Click"
                                Style="{StaticResource TransparentButton}"
                                ToolTip="联网搜索: 已关闭"
                                FontSize="14" Padding="6,0" Margin="0,0,4,0"
                                Foreground="#888888">
                            <Button.Content>
                                <TextBlock Text="🌐" FontSize="14" />
                            </Button.Content>
                        </Button>
                        <!-- MCP 配置按钮 -->
                        <Button x:Name="McpConfigButton"
                                Click="McpConfigButton_Click"
                                Style="{StaticResource TransparentButton}"
                                ToolTip="配置 MCP 服务器"
                                FontSize="14" Padding="6,0" Margin="0,0,4,0"
                                Foreground="#888888">
                            <Button.Content>
                                <TextBlock Text="🔌" FontSize="14" />
                            </Button.Content>
                        </Button>
                        <Button x:Name="NewChatButton" Content="+ 新对话" Click="NewChatButton_Click"
                                Style="{StaticResource TransparentButton}"
                                Margin="0,0,8,0" FontSize="12"
                                Foreground="#4EC9B0" />
                        <Button x:Name="ClearButton" Content="清空" Click="ClearButton_Click"
                                Style="{StaticResource TransparentButton}"
                                Margin="0,0,4,0" />
                        <Button x:Name="StopButton" Content="⏹"
                                Click="StopButton_Click"
                                Style="{StaticResource TransparentButton}"
                                FontSize="14" Padding="8,0"
                                Visibility="Collapsed" />
                        <Button x:Name="SendButton" Content="➤"
                                Click="SendButton_Click"
                                Style="{StaticResource TransparentButton}"
                                Foreground="#6CAFD9" FontSize="14" Padding="8,0" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
