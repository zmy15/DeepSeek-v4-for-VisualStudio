<Window x:Class="DeepSeek_v4_for_VisualStudio.View.DiffViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:utils="clr-namespace:DeepSeek_v4_for_VisualStudio.Utils"
        Title="{utils:I18n diff.windowTitle}"
        MinWidth="900" MinHeight="500"
        Width="1100" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Foreground="#D4D4D4"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <Border Grid.Row="0"
                Background="#2D2D30"
                BorderBrush="#3F3F46"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 查看模式切换 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="InlineModeButton"
                            Content="{utils:I18n diff.inlineMode}"
                            Click="InlineModeButton_Click"
                            Background="#264F78"
                            Foreground="White"
                            BorderBrush="#3F6A9A"
                            BorderThickness="1"
                            MinWidth="80" MinHeight="26"
                            FontSize="11" FontWeight="SemiBold"
                            Cursor="Hand"
                            Padding="8,3" />
                    <Button x:Name="SideBySideModeButton"
                            Content="{utils:I18n diff.sideBySideMode}"
                            Click="SideBySideModeButton_Click"
                            Background="#3C3C3C"
                            Foreground="#D4D4D4"
                            BorderBrush="#555555"
                            BorderThickness="1"
                            MinWidth="80" MinHeight="26"
                            FontSize="11"
                            Cursor="Hand"
                            Padding="8,3"
                            Margin="4,0,0,0" />
                </StackPanel>

                <!-- 变更统计 -->
                <TextBlock Grid.Column="1"
                           x:Name="StatsLabel"
                           Foreground="#A0A0A0"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0" />

                <!-- 差异导航 -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button x:Name="PrevDiffButton"
                            Content="{utils:I18n diff.previousChange}"
                            Click="PrevDiffButton_Click"
                            Background="#3C3C3C"
                            Foreground="#D4D4D4"
                            BorderBrush="#555555"
                            BorderThickness="1"
                            MinWidth="80" MinHeight="26"
                            FontSize="11"
                            Cursor="Hand"
                            Padding="8,3" />
                    <Button x:Name="NextDiffButton"
                            Content="{utils:I18n diff.nextChange}"
                            Click="NextDiffButton_Click"
                            Background="#3C3C3C"
                            Foreground="#D4D4D4"
                            BorderBrush="#555555"
                            BorderThickness="1"
                            MinWidth="80" MinHeight="26"
                            FontSize="11"
                            Cursor="Hand"
                            Padding="8,3"
                            Margin="4,0,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="16,0,0,0">
                    <Button x:Name="UndoButton"
                            Content="{utils:I18n diff.undoChanges}"
                            Click="UndoButton_Click"
                            Background="#8B2E2E"
                            Foreground="White"
                            BorderBrush="#B84040"
                            BorderThickness="1"
                            MinWidth="90" MinHeight="28"
                            FontSize="12" FontWeight="SemiBold"
                            Cursor="Hand"
                            Padding="12,4" />
                    <Button x:Name="AcceptButton"
                            Content="{utils:I18n diff.confirmChanges}"
                            Click="AcceptButton_Click"
                            Background="#2E7D32"
                            Foreground="White"
                            BorderBrush="#4CAF50"
                            BorderThickness="1"
                            MinWidth="90" MinHeight="28"
                            FontSize="12" FontWeight="SemiBold"
                            Cursor="Hand"
                            Padding="12,4"
                            Margin="8,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Diff 查看器宿主 -->
        <Border Grid.Row="1"
                x:Name="DiffViewerHost"
                Background="#1E1E1E" />

        <!-- 底部状态栏 -->
        <Border Grid.Row="2"
                Background="#007ACC"
                Padding="12,6">
            <TextBlock x:Name="BottomStatusLabel"
                       Foreground="White"
                       FontSize="11"
                       Text="{utils:I18n diff.guideText}" />
        </Border>
    </Grid>
</Window>
